[Desktop Entry]
Version=1.0
Type=Application
Name=word-sys's PDF Editor
Comment=Edit text content in PDF files
Exec=word-sys-pdf-editor %F
Icon=f-pv1
Terminal=false
Categories=Office;Graphics;GTK;
Keywords=PDF;Editor;Text;word-sys;
MimeType=application/pdf;
StartupNotify=true
StartupWMClass=org.word-sys.pdfeditor
